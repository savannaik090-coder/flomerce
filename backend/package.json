{
  "name": "saas-platform-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for SaaS platform",
  "type": "module",
  "main": "workers/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create saas-platform-db",
    "db:migrate": "wrangler d1 execute saas-platform-db --file=./schema/d1-schema.sql",
    "db:migrate:local": "wrangler d1 execute saas-platform-db --local --file=./schema/d1-schema.sql",
    "r2:create": "wrangler r2 bucket create saas-platform-storage",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
